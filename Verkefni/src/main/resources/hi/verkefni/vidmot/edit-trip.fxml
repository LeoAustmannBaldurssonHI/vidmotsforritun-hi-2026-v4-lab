<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="1000.0" stylesheets="@CSS/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="hi.verkefni.vidmot.controllers.EditController">
   <children>
      <HBox fx:id="fxHeader" prefHeight="60.0" prefWidth="1000.0">
         <children>
            <Label fx:id="userHeader" alignment="CENTER" contentDisplay="CENTER" prefHeight="60.0" prefWidth="931.0" styleClass="userHeader" stylesheets="@CSS/style.css" text="{username},  you’re currently editing: {tripTitle}">
               <font>
                  <Font size="24.0" />
               </font>
            </Label>
            <Button fx:id="homePage" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#directHome" prefHeight="69.0" prefWidth="79.0" styleClass="userHeader_homeButton" stylesheets="@CSS/style.css">
               <font>
                  <Font size="18.0" />
               </font>
            </Button>
         </children>
      </HBox>
      <VBox layoutY="514.0" prefHeight="72.0" prefWidth="1000.0">
         <children>
            <HBox fx:id="viewButtonsManagementLABELS" alignment="CENTER" prefHeight="23.0" prefWidth="1000.0" spacing="245.0">
               <children>
                  <Label alignment="CENTER" contentDisplay="CENTER" text="Want to add a new trip?">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
                  <Label alignment="CENTER" contentDisplay="CENTER" text="Delete the selected trip?">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
                  <Label alignment="CENTER" contentDisplay="CENTER" text="View the selected trip?">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
            <HBox fx:id="viewButtonsManagement" alignment="CENTER" prefHeight="23.0" prefWidth="1000.0" spacing="330.0">
               <children>
                  <Button fx:id="edit_newTrip" alignment="CENTER" mnemonicParsing="false" onAction="#directNew" styleClass="buttons" text="New Trip">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Button>
                  <Button fx:id="edit_deleteTrip" alignment="CENTER" mnemonicParsing="false" onAction="#directDelete" styleClass="buttons" text="Delete Trip">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Button>
                  <Button fx:id="edit_viewTrip" alignment="CENTER" mnemonicParsing="false" onAction="#directView" styleClass="buttons" text="View Trip">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
         </children>
      </VBox>
      <Label alignment="CENTER" layoutY="81.0" prefHeight="30.0" prefWidth="1000.0" styleClass="infoHeaders" text="General Information" />
      <Label alignment="CENTER" layoutY="222.0" prefHeight="30.0" prefWidth="1000.0" styleClass="infoHeaders" text="Other information" />
      <Label alignment="CENTER" layoutY="370.0" prefHeight="30.0" prefWidth="1000.0" styleClass="infoHeaders" text="Trip finance" />
      <VBox layoutY="123.0" prefHeight="100.0" prefWidth="1000.0">
         <children>
            <HBox prefHeight="100.0" prefWidth="200.0" spacing="50.0">
               <children>
                  <Label alignment="CENTER" prefHeight="30.0" prefWidth="170.0" styleClass="tripCard" text="Title" />
                  <Label alignment="CENTER" layoutX="10.0" layoutY="10.0" prefHeight="30.0" prefWidth="170.0" styleClass="tripCard" text="Destination" />
                  <Label alignment="CENTER" layoutX="180.0" layoutY="10.0" prefHeight="30.0" prefWidth="170.0" styleClass="tripCard" text="Start" />
                  <Label alignment="CENTER" layoutX="350.0" layoutY="10.0" prefHeight="30.0" prefWidth="170.0" styleClass="tripCard" text="End" />
                  <Label alignment="CENTER" layoutX="521.0" layoutY="10.0" prefHeight="30.0" prefWidth="170.0" styleClass="tripCard" text="Cost" />
               </children>
            </HBox>
            <HBox layoutX="10.0" layoutY="10.0" prefHeight="100.0" prefWidth="200.0" spacing="50.0">
               <children>
                  <TextField fx:id="title" prefWidth="170.0" />
                  <TextField fx:id="destination" layoutX="10.0" layoutY="10.0" prefWidth="170.0" />
                  <DatePicker fx:id="start" prefHeight="25.0" prefWidth="170.0" />
                  <DatePicker fx:id="end" layoutX="451.0" layoutY="10.0" prefHeight="25.0" prefWidth="170.0" />
                  <Label fx:id="totalCostLabel" alignment="CENTER" layoutX="521.0" layoutY="10.0" prefHeight="30.0" prefWidth="170.0" styleClass="infoLabels" text="{total cost}" />
               </children>
            </HBox>
         </children>
      </VBox>
      <VBox layoutY="414.0" prefHeight="100.0" prefWidth="1000.0">
         <children>
            <HBox prefHeight="100.0" prefWidth="200.0" spacing="50.0">
               <children>
                  <Label alignment="CENTER" prefHeight="30.0" prefWidth="300.0" styleClass="tripCard" text="Flight Cost" />
                  <Label alignment="CENTER" layoutX="10.0" layoutY="10.0" prefHeight="30.0" prefWidth="300.0" styleClass="tripCard" text="Hotel cost" />
                  <Label alignment="CENTER" layoutX="180.0" layoutY="10.0" prefHeight="30.0" prefWidth="300.0" styleClass="tripCard" text="Car Cost" />
               </children>
            </HBox>
            <HBox layoutX="10.0" layoutY="10.0" prefHeight="100.0" prefWidth="200.0" spacing="50.0">
               <children>
                  <TextField fx:id="flightCost" prefWidth="300.0" />
                  <TextField fx:id="hotelCost" layoutX="10.0" layoutY="10.0" prefWidth="300.0" />
                  <TextField fx:id="carCost" layoutX="360.0" layoutY="10.0" prefWidth="300.0" />
               </children>
            </HBox>
         </children>
      </VBox>
      <VBox layoutY="266.0" prefHeight="100.0" prefWidth="1000.0">
         <children>
            <HBox prefHeight="100.0" prefWidth="200.0" spacing="50.0">
               <children>
                  <Label alignment="CENTER" prefHeight="30.0" prefWidth="170.0" styleClass="tripCard" text="Is this a work trip?" />
                  <Label alignment="CENTER" layoutX="10.0" layoutY="10.0" prefHeight="30.0" prefWidth="170.0" styleClass="tripCard" text="Booked a rental car?" />
                  <Label alignment="CENTER" layoutX="180.0" layoutY="10.0" prefHeight="30.0" prefWidth="170.0" styleClass="tripCard" text="Hotel booked?" />
                  <Label alignment="CENTER" layoutX="350.0" layoutY="10.0" prefHeight="30.0" prefWidth="170.0" styleClass="tripCard" text="Flights booked?" />
                  <Label alignment="CENTER" layoutX="521.0" layoutY="10.0" prefHeight="30.0" prefWidth="170.0" styleClass="tripCard" text="Group Size" />
               </children>
            </HBox>
            <HBox layoutX="10.0" layoutY="10.0" prefHeight="100.0" prefWidth="200.0" spacing="50.0">
               <children>
                  <Label fx:id="updateWork" alignment="CENTER" prefHeight="30.0" prefWidth="170.0" styleClass="infoLabels" text="{work}" />
                  <Label fx:id="updateCar" alignment="CENTER" layoutX="10.0" layoutY="10.0" prefHeight="30.0" prefWidth="170.0" styleClass="infoLabels" text="{car}" />
                  <Label fx:id="updateHotel" alignment="CENTER" layoutX="180.0" layoutY="10.0" prefHeight="30.0" prefWidth="170.0" styleClass="infoLabels" text="{hotel}" />
                  <Label fx:id="updateFlight" alignment="CENTER" layoutX="350.0" layoutY="10.0" prefHeight="30.0" prefWidth="170.0" styleClass="infoLabels" text="{flights}" />
                  <TextField fx:id="groupSize" prefHeight="25.0" prefWidth="170.0" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
