<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="userLabel" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="1000.0" stylesheets="@CSS/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="hi.verkefni.vidmot.controllers.ViewController">
   <children>
      <VBox layoutY="514.0" prefHeight="72.0" prefWidth="1000.0">
         <children>
            <HBox fx:id="viewButtonsManagementLABELS" alignment="CENTER" prefHeight="23.0" prefWidth="1000.0" spacing="250.0">
               <children>
                  <Label alignment="CENTER" contentDisplay="CENTER" text="Want to add a new trip?">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
                  <Label alignment="CENTER" contentDisplay="CENTER" text="Delete the selected trip?">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
                  <Label alignment="CENTER" contentDisplay="CENTER" text="Edit the selected trip?">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
            <HBox fx:id="viewButtonsManagement" alignment="CENTER" prefHeight="23.0" prefWidth="1000.0" spacing="285.0">
               <children>
                  <Button fx:id="view_newTrip" alignment="CENTER" mnemonicParsing="false" styleClass="buttons" text="New Trip">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Button>
                  <Button fx:id="view_deleteTrip" alignment="CENTER" mnemonicParsing="false" styleClass="buttons" text="Delete Trip">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Button>
                  <Button fx:id="view_editTrip" alignment="CENTER" mnemonicParsing="false" styleClass="buttons" text="Edit Trip">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
         </children>
      </VBox>
      <HBox fx:id="fxHeader" prefHeight="60.0" prefWidth="1000.0">
         <children>
            <Label fx:id="userHeader" alignment="CENTER" contentDisplay="CENTER" prefHeight="60.0" prefWidth="931.0" styleClass="userHeader" stylesheets="@CSS/style.css" text="{username},  you’re currently viewing: {tripTitle}">
               <font>
                  <Font size="24.0" />
               </font>
            </Label>
            <Button fx:id="homePage" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#goHome" prefHeight="69.0" prefWidth="79.0" styleClass="userHeader_homeButton" stylesheets="@CSS/style.css">
               <font>
                  <Font size="18.0" />
               </font>
            </Button>
         </children>
      </HBox>
      <AnchorPane fx:id="tripCards" layoutY="60.0" prefHeight="453.0" prefWidth="1000.0">
         <children>
            <Label fx:id="tripCountdown" alignment="CENTER" layoutX="97.0" layoutY="6.0" prefHeight="30.0" prefWidth="790.0" styleClass="countdowner" text="{days} until this trip begins" />
            <Label alignment="CENTER" layoutY="43.0" prefHeight="30.0" prefWidth="1000.0" styleClass="infoHeaders" text="General Information" />
            <VBox layoutY="82.0" prefHeight="100.0" prefWidth="1000.0">
               <children>
                  <HBox prefHeight="100.0" prefWidth="200.0" spacing="50.0">
                     <children>
                        <Label alignment="CENTER" prefHeight="30.0" prefWidth="170.0" styleClass="tripCard" text="Title" />
                        <Label alignment="CENTER" layoutX="10.0" layoutY="10.0" prefHeight="30.0" prefWidth="170.0" styleClass="tripCard" text="Destination" />
                        <Label alignment="CENTER" layoutX="180.0" layoutY="10.0" prefHeight="30.0" prefWidth="170.0" styleClass="tripCard" text="Start" />
                        <Label alignment="CENTER" layoutX="350.0" layoutY="10.0" prefHeight="30.0" prefWidth="170.0" styleClass="tripCard" text="End" />
                        <Label alignment="CENTER" layoutX="521.0" layoutY="10.0" prefHeight="30.0" prefWidth="170.0" styleClass="tripCard" text="Cost" />
                     </children>
                  </HBox>
                  <HBox layoutX="10.0" layoutY="10.0" prefHeight="100.0" prefWidth="200.0" spacing="50.0">
                     <children>
                        <Label fx:id="viewTitleLabel" alignment="CENTER" prefHeight="30.0" prefWidth="170.0" styleClass="infoLabels" text="{title}" />
                        <Label fx:id="viewDestinationLabel" alignment="CENTER" layoutX="10.0" layoutY="10.0" prefHeight="30.0" prefWidth="170.0" styleClass="infoLabels" text="{destination}" />
                        <Label fx:id="viewStartLabel" alignment="CENTER" layoutX="180.0" layoutY="10.0" prefHeight="30.0" prefWidth="170.0" styleClass="infoLabels" text="{start}" />
                        <Label fx:id="viewEndLabel" alignment="CENTER" layoutX="350.0" layoutY="10.0" prefHeight="30.0" prefWidth="170.0" styleClass="infoLabels" text="{end}" />
                        <Label fx:id="viewTotalCostLabel" alignment="CENTER" layoutX="521.0" layoutY="10.0" prefHeight="30.0" prefWidth="170.0" styleClass="infoLabels" text="{total cost}" />
                     </children>
                  </HBox>
               </children>
            </VBox>
            <VBox layoutY="213.0" prefHeight="100.0" prefWidth="1000.0">
               <children>
                  <HBox prefHeight="100.0" prefWidth="200.0" spacing="50.0">
                     <children>
                        <Label alignment="CENTER" prefHeight="30.0" prefWidth="170.0" styleClass="tripCard" text="Is this a work trip?" />
                        <Label alignment="CENTER" layoutX="10.0" layoutY="10.0" prefHeight="30.0" prefWidth="170.0" styleClass="tripCard" text="Booked a rental car?" />
                        <Label alignment="CENTER" layoutX="180.0" layoutY="10.0" prefHeight="30.0" prefWidth="170.0" styleClass="tripCard" text="Hotel booked?" />
                        <Label alignment="CENTER" layoutX="350.0" layoutY="10.0" prefHeight="30.0" prefWidth="170.0" styleClass="tripCard" text="Flights booked?" />
                        <Label alignment="CENTER" layoutX="521.0" layoutY="10.0" prefHeight="30.0" prefWidth="170.0" styleClass="tripCard" text="Group Size" />
                     </children>
                  </HBox>
                  <HBox layoutX="10.0" layoutY="10.0" prefHeight="100.0" prefWidth="200.0" spacing="50.0">
                     <children>
                        <Label fx:id="viewWorkLabel" alignment="CENTER" prefHeight="30.0" prefWidth="170.0" styleClass="infoLabels" text="{work}" />
                        <Label fx:id="viewCarLabel" alignment="CENTER" layoutX="10.0" layoutY="10.0" prefHeight="30.0" prefWidth="170.0" styleClass="infoLabels" text="{car}" />
                        <Label fx:id="viewHotelLabel" alignment="CENTER" layoutX="180.0" layoutY="10.0" prefHeight="30.0" prefWidth="170.0" styleClass="infoLabels" text="{hotel}" />
                        <Label fx:id="viewFlightsLabel" alignment="CENTER" layoutX="350.0" layoutY="10.0" prefHeight="30.0" prefWidth="170.0" styleClass="infoLabels" text="{flights}" />
                        <Label fx:id="viewSizeLabel" alignment="CENTER" layoutX="521.0" layoutY="10.0" prefHeight="30.0" prefWidth="170.0" styleClass="infoLabels" text="{size}" />
                     </children>
                  </HBox>
               </children>
            </VBox>
            <Label alignment="CENTER" layoutY="174.0" prefHeight="30.0" prefWidth="1000.0" styleClass="infoHeaders" text="Other information" />
            <Label alignment="CENTER" layoutY="304.0" prefHeight="30.0" prefWidth="1000.0" styleClass="infoHeaders" text="Trip finance" />
            <VBox layoutY="343.0" prefHeight="100.0" prefWidth="1000.0">
               <children>
                  <HBox prefHeight="100.0" prefWidth="200.0" spacing="50.0">
                     <children>
                        <Label alignment="CENTER" prefHeight="30.0" prefWidth="300.0" styleClass="tripCard" text="Flight Cost" />
                        <Label alignment="CENTER" layoutX="10.0" layoutY="10.0" prefHeight="30.0" prefWidth="300.0" styleClass="tripCard" text="Hotel cost" />
                        <Label alignment="CENTER" layoutX="180.0" layoutY="10.0" prefHeight="30.0" prefWidth="300.0" styleClass="tripCard" text="Car Cost" />
                     </children>
                  </HBox>
                  <HBox layoutX="10.0" layoutY="10.0" prefHeight="100.0" prefWidth="200.0" spacing="50.0">
                     <children>
                        <Label fx:id="viewFlightCostLabel" alignment="CENTER" prefHeight="30.0" prefWidth="300.0" styleClass="infoLabels" text="{flight cost}" />
                        <Label fx:id="viewHotelCostLabel" alignment="CENTER" layoutX="10.0" layoutY="10.0" prefHeight="30.0" prefWidth="300.0" styleClass="infoLabels" text="{hotel cost}" />
                        <Label fx:id="viewCarCostLabel" alignment="CENTER" layoutX="180.0" layoutY="10.0" prefHeight="30.0" prefWidth="300.0" styleClass="infoLabels" text="{car cost}" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </AnchorPane>
   </children>
</AnchorPane>
